# =====================================================================
# LinkedIn Leads — credential template
#
# Copy this file to `.env` (which is gitignored) and fill in your own
# values. Probe scripts under execution/probe/ read these via dotenv.
#
# Required for the pipeline to run: ANTHROPIC_API_KEY, NOTION_TOKEN,
# NOTION_DB_ID, SLACK_BOT_TOKEN, SLACK_CHANNEL_ID, GOOGLE_*, LI_*.
# See README.md → "Getting started" for where each value comes from.
# =====================================================================

# --- Claude API (Anthropic) ---
# Get from https://console.anthropic.com/ → API keys
ANTHROPIC_API_KEY=

# --- Notion (used as the lead CRM / system of record) ---
# Token: https://www.notion.so/my-integrations → New integration
# DB id: run `node execution/setup/notion_create_db.mjs` to auto-create
NOTION_TOKEN=
NOTION_DB_ID=

# --- Slack (per-reply alerts + daily digest) ---
# Bot token: https://api.slack.com/apps → Your app → OAuth & Permissions
# Channel id: right-click the channel in Slack → View channel details
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# --- Gmail OAuth (for email follow-ups, optional) ---
# https://console.cloud.google.com/ → OAuth client (Desktop app)
# After credentials, run `node execution/setup/gmail_authorize.mjs`
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=

# --- LinkedIn ---
# Use a dedicated account you control. The session cookie is captured
# interactively by `npm run linkedin:capture` and saved to
# linkedin_storage_state.json (gitignored).
LI_EMAIL=
LI_PASSWORD=

# --- Runtime safety ---
# DRY_RUN=true means the pipeline logs what it WOULD send but does NOT
# actually hit LinkedIn or Gmail. Flip to false only after you've
# verified output looks right in the dashboard.
DRY_RUN=true

# Operator timezone — controls the 09:00–17:00 weekday send window.
OPERATOR_TIMEZONE=America/New_York

# Operator first name — used in email signatures and personalization.
OPERATOR_FIRST_NAME=Operator
